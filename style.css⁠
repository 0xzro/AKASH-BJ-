/* RESET & FONTS */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: #0b0f19;
    color: #f3f4f6;
    line-height: 1.6;
    padding: 0;
}

.container {
    width: 90%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 0;
}

/* HERO SECTION */
.hero-section {
    background: linear-gradient(135deg, #111827 0%, #0b0f19 100%);
    border-bottom: 1px solid #1f2937;
}

.hero-section h1 {
    font-size: 3rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
}

.tagline {
    font-size: 1.5rem;
    color: #9ca3af;
    margin-bottom: 2rem;
}

.tagline strong {
    color: #10b981; /* Crypto Green Accent */
}

.bio {
    font-size: 1.15rem;
    color: #d1d5db;
    max-width: 800px;
    margin-bottom: 2.5rem;
}

/* BUTTONS */
.cta-buttons {
    display: flex;
    gap: 1rem;
}

.btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
}

.btn-primary {
    background-color: #10b981;
    color: #0b0f19;
}

.btn-primary:hover {
    background-color: #059669;
}

.btn-secondary {
    border: 1px solid #374151;
    color: #ffffff;
}

.btn-secondary:hover {
    background-color: #1f2937;
}

/* SERVICES GRID */
.services-section h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    color: #ffffff;
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
}

.service-card {
    background-color: #111827;
    border: 1px solid #1f2937;
    padding: 2.5rem 2rem;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
}

.service-card.highlight {
    border-color: #10b981;
    background: linear-gradient(180deg, #111827 0%, #0d1e1a 100%);
}

.service-card h3 {
    font-size: 1.35rem;
    color: #ffffff;
    margin-bottom: 0.75rem;
}

.conversation-prompt {
    font-style: italic;
    color: #6b7280;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    border-left: 2px solid #374151;
    padding-left: 0.5rem;
}

.service-card.highlight .conversation-prompt {
    border-color: #10b981;
}

.service-desc {
    color: #9ca3af;
    font-size: 1rem;
    margin-bottom: 2rem;
    flex-grow: 1;
}

.card-cta {
    color: #10b981;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
}

.card-cta:hover {
    color: #34d399;
    text-decoration: underline;
}

/* INSIGHTS / STABLE MARKET SECTION */
.insights-section {
    background-color: #0d1322;
    border-top: 1px solid #1f2937;
    border-bottom: 1px solid #1f2937;
}

.insights-section h2 {
    font-size: 2rem;
    color: #ffffff;
    margin-bottom: 1.5rem;
}

.insight-content p {
    font-size: 1.1rem;
    color: #9ca3af;
    margin-bottom: 1.5rem;
}

.insight-content ul {
    list-style-type: none;
}

.insight-content li {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    position: relative;
    color: #d1d5db;
}

.insight-content li::before {
    content: "•";
    color: #10b981;
    font-size: 1.5rem;
    position: absolute;
    left: 0;
    top: -0.2rem;
}

/* FOOTER SECTION */
.footer-section {
    text-align: center;
    background-color: #0b0f19;
}

.footer-section h2 {
    font-size: 2.5rem;
    color: #ffffff;
    margin-bottom: 1rem;
}

.footer-section p {
    color: #9ca3af;
    max-width: 600px;
    margin: 0 auto 2rem auto;
}

.footer-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 3rem;
}

.link-item {
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px dashed #4b5563;
    padding-bottom: 0.25rem;
}

.link-item:hover {
    color: #10b981;
    border-bottom-color: #10b981;
}

.copyright {
    font-size: 0.85rem;
    color: #4b5563 !important;
}

/* RESPONSIVE DESIGN */
@media (max-width: 768px) {
    .hero-section h1 { font-size: 2.25rem; }
    .cta-buttons { flex-direction: column; }
    .footer-links { flex-direction: column; gap: 1rem; }
}

